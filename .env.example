# Toolbox Configuration
# Copy to .env and adjust values

# ─── API ──────────────────────────────────────────────────────────────────────
TOOLBOX_PORT=9600

# Set to a random secret to require authentication on all endpoints.
# Leave empty (or unset) to run without authentication.
API_KEY=

# ─── Backend URLs (internal Docker network) ───────────────────────────────────
# These are container-to-container URLs. Don't change unless custom setup.
SEARXNG_URL=http://searxng:8080
CAMOUFOX_URL=http://camoufox:8790
WHISPER_URL=http://whisper:8200

# ─── LLM (required for: describe, summarize, extract) ────────────────────────
# Must be OpenAI-compatible with vision support. See SETUP_LLM_HOST.md for options.
# Examples:
#   llama.cpp:  http://192.168.1.100:8080/v1  (remote GPU host)
#   Ollama:     http://host.docker.internal:11434/v1  (same machine)
#   OpenAI:     https://api.openai.com/v1
LLM_URL=http://host.docker.internal:8080/v1
LLM_API_KEY=your-api-key
# Model name passed to the LLM endpoint. Must match what your server expects.
# Examples: qwen3-vl-8b, gpt-4o-mini, qwen2.5-vl-7b, llava-v1.6
LLM_MODEL=qwen3-vl-8b
LLM_MAX_CONCURRENT=1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=512

# ─── Fetch ────────────────────────────────────────────────────────────────────
FETCH_TIMEOUT_SECONDS=30

# ─── Browser ──────────────────────────────────────────────────────────────────
CAMOUFOX_TZ=UTC

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_DB_PATH=/data/cache.db

# ─── SearXNG ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SEARXNG_SECRET=
